---
import { Image } from 'astro:assets';
import favicon from '../assets/favicon.png';
import { profile } from '../data/profile';
import ThemeSwitch from './ThemeSwitch.astro';

const pathname = Astro.url.pathname;
const projectsActive = pathname.startsWith('/projects/');
const resumeActive = pathname === '/resume/';
---

<header class="site-header">
	<div class="header-inner">
		<a class="site-brand" href="/" aria-label={`${profile.name} - home`}>
			<Image src={favicon} width={40} densities={[1, 2]} format="webp" alt="" loading="eager" />
		</a>
		<nav class="main-nav" aria-label="Main">
			<ul>
				<li><a href="/projects/" aria-current={projectsActive ? 'page' : undefined}>Projects</a></li>
				<li><a href="/resume/" aria-current={resumeActive ? 'page' : undefined}>Resume</a></li>
				<li><a href="/#contact">Contact</a></li>
			</ul>
		</nav>
		<ThemeSwitch />
	</div>
</header>
