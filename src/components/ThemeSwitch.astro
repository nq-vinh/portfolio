<button class="theme-toggle" type="button" aria-pressed="false" data-theme-toggle>
	<span class="visually-hidden">Dark theme</span>
	<svg
		class="icon-sun"
		viewBox="0 0 24 24"
		width="18"
		height="18"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<circle cx="12" cy="12" r="4"></circle>
		<path
			d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
		></path>
	</svg>
	<svg
		class="icon-moon"
		viewBox="0 0 24 24"
		width="18"
		height="18"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
	</svg>
</button>

<script is:inline>
	(() => {
		const media = window.matchMedia('(prefers-color-scheme: dark)');
		const toggles = document.querySelectorAll('[data-theme-toggle]');

		const storedTheme = () => {
			try {
				return localStorage.getItem('theme');
			} catch {
				return null;
			}
		};

		const effectiveTheme = () => {
			const stored = storedTheme();
			if (stored === 'light' || stored === 'dark') return stored;
			return media.matches ? 'dark' : 'light';
		};

		const render = () => {
			const isDark = effectiveTheme() === 'dark';
			toggles.forEach((toggle) => toggle.setAttribute('aria-pressed', String(isDark)));
		};

		toggles.forEach((toggle) => {
			toggle.addEventListener('click', () => {
				const next = effectiveTheme() === 'dark' ? 'light' : 'dark';

				/* an override matching the system preference is dropped so the site keeps following the OS setting */
				if (next === (media.matches ? 'dark' : 'light')) {
					delete document.documentElement.dataset.theme;
					try {
						localStorage.removeItem('theme');
					} catch {}
				} else {
					document.documentElement.dataset.theme = next;
					try {
						localStorage.setItem('theme', next);
					} catch {}
				}

				render();
			});
		});

		media.addEventListener('change', render);
		render();
	})();
</script>
