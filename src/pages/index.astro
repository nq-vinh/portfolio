---
import { Picture } from 'astro:assets';
import HeroMeta from '../components/HeroMeta.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SocialLinks from '../components/SocialLinks.astro';
import TagList from '../components/TagList.astro';
import Base from '../layouts/Base.astro';
import portrait from '../assets/portrait.jpeg';
import { profile } from '../data/profile';
import { getPublishedProjects } from '../lib/projects';

const projects = await getPublishedProjects();
const featuredProjects = projects.filter(({ data }) => data.featured);

if (featuredProjects.length === 0) throw new Error('The homepage requires a featured project.');

const otherProjects = projects.filter(({ data }) => !data.featured);
const title = `${profile.name} - ${profile.role}`;
---

<Base title={title} description={profile.metaDescription}>
	<div class="content">
		<div class="hero">
			<div class="hero-copy">
				<h1>Hi, I'm <strong>{profile.shortName}</strong></h1>
				<p class="hero-role">{profile.role}</p>
				<p class="hero-introduction">{profile.tagline}</p>
			</div>
			<Picture
				pictureAttributes={{ class: 'portrait' }}
				src={portrait}
				formats={['avif', 'webp']}
				widths={[112, 224]}
				sizes="112px"
				width="112"
				height="112"
				alt={`Portrait of ${profile.name}`}
				loading="eager"
			/>
			<HeroMeta />
		</div>

		<section id="projects" class="content-section" aria-label="Featured case studies">
			<p class="eyebrow">Featured case {featuredProjects.length > 1 ? 'studies' : 'study'}</p>
			{featuredProjects.map((project) => (
				<article class="featured-project" aria-labelledby={`featured-${project.id}-title`}>
					<h2 class="featured-project-title" id={`featured-${project.id}-title`} style={`view-transition-name: project-${project.id}`}>{project.data.title}</h2>
					<p class="project-summary">{project.data.summary}</p>
					<div class="project-card">
						<ul class="hook-list">
							{project.data.hooks.map((hook) => (
								<li class="hook">
									<p class="hook-misconception">"{hook.misconception}"</p>
									<h3 class="hook-question">{hook.question}</h3>
									<p class="hook-answer">
										<strong>{hook.metric}.</strong> {hook.detail}
										<a href={`/projects/${project.id}/#${hook.id}`}>
											How<span class="visually-hidden"> - {hook.question}</span> →
										</a>
									</p>
								</li>
							))}
						</ul>
						<TagList items={project.data.tags} label={`${project.data.title} technologies`} />
						<div class="project-actions">
							<a href={`/projects/${project.id}/`}>Read the case study →</a>
							{project.data.live && <a href={project.data.live}>Visit the live app</a>}
							{project.data.repo && <a href={project.data.repo}>View source</a>}
						</div>
					</div>
				</article>
			))}
			{otherProjects.length > 0 && (
				<div class="project-list project-list-secondary">
					<h3>More projects</h3>
					{otherProjects.map((project) => (
						<article class="project">
							<h3>
								<a href={`/projects/${project.id}/`}>{project.data.title}</a>
							</h3>
							<p>{project.data.summary}</p>
							<TagList items={project.data.tags} label={`${project.data.title} technologies`} />
						</article>
					))}
				</div>
			)}
		</section>

		<section id="now" class="content-section" aria-labelledby="now-title">
			<SectionHeader headingId="now-title" title="Now" />
			<ul class="now-list">
				{profile.now.map((item) => <li>{item}</li>)}
			</ul>
			<a href="/resume/">Full resume →</a>
		</section>

		<section id="contact" class="content-section contact" aria-labelledby="contact-title">
			<SectionHeader headingId="contact-title" title="Contact" />
			<p>The fastest way to reach me is email. I'm open to senior frontend roles in the Rhein-Main area or remote.</p>
			<a class="contact-email" href={`mailto:${profile.email}`}>{profile.email}</a>
			<ul class="contact-links" aria-label="Social links">
				<SocialLinks />
			</ul>
		</section>
	</div>
</Base>
