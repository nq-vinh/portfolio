---
import TagList from '../../components/TagList.astro';
import Base from '../../layouts/Base.astro';
import { profile } from '../../data/profile';
import { getPublishedProjects } from '../../lib/projects';

const projects = await getPublishedProjects();

const title = `Projects · ${profile.name}`;
const description = `Case studies from ${profile.name}, a ${profile.role}.`;
---

<Base title={title} description={description}>
	<div class="content">
		<section class="content-section project-index" aria-labelledby="projects-title">
			<p class="eyebrow">Selected work</p>
			<h1 id="projects-title">Projects</h1>
			<div class="project-list">
				{projects.map((project) => (
					<article class="project">
						<h2>
							<a href={`/projects/${project.id}/`}>{project.data.title}</a>
						</h2>
						<p>{project.data.summary}</p>
						<TagList items={project.data.tags} label={`${project.data.title} technologies`} />
					</article>
				))}
			</div>
		</section>
	</div>
</Base>
